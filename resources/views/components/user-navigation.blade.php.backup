// Cancel edit
function cancelEdit() {
    const inputs = document.querySelectorAll('.profile-input:not(#profileSchoolId)');
    inputs.forEach(input => input.setAttribute('readonly', true));
    
    document.getElementById('pictureInput').setAttribute('disabled', true);
